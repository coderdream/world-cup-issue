{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "视频工坊",
  "version": "0.1.14",
  "identifier": "com.coderdream.videoCreator",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:1421",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "视频工坊",
        "width": 1380,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "decorations": false,
        "resizable": true,
        "center": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "publisher": "Coderdream",
    "copyright": "Copyright 2026 Coderdream",
    "category": "Video",
    "shortDescription": "视频工坊桌面工作台",
    "longDescription": "基于 Tauri 的 BBC 六分钟视频创作工作台，复用 Video Easy Creator 的成熟 Java 能力。",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "perMachine",
        "languages": ["SimpChinese"],
        "displayLanguageSelector": false
      }
    }
  },
  "plugins": {}
}
