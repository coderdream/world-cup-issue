{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WorldCupIssue",
  "version": "0.1.11",
  "identifier": "com.worldcupissue.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "WorldCupIssue（世界杯组手）",
        "width": 1330,
        "height": 953,
        "minWidth": 980,
        "minHeight": 720,
        "decorations": false,
        "resizable": true,
        "center": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis"],
    "publisher": "WorldCupIssue",
    "copyright": "Copyright 2026 WorldCupIssue",
    "category": "Sports",
    "shortDescription": "2026 世界杯桌面比分助手",
    "longDescription": "WorldCupIssue（世界杯组手）是一款复刻 CupWatch 公开可见体验的独立第三方世界杯赛事资讯桌面工具。",
    "externalBin": [],
    "resources": [],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "perMachine",
        "languages": ["SimpChinese"],
        "displayLanguageSelector": false
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/coderdream/world-cup-issue/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhGMkM2QUQxOUU4RTVFRTIKUldUaVhvNmUwV29zajNkdTFpVlVIQnNXdDFlS3dYK2FCWkFDeTZ6a0tzT012aXBvK1J1Q1ZnL00K",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}

