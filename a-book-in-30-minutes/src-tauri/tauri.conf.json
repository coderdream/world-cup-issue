{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "A Book in 30 Minutes",
  "version": "0.1.95",
  "identifier": "com.abookin30minutes.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:1421",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "A Book in 30 Minutes",
        "width": 1180,
        "height": 820,
        "minWidth": 920,
        "minHeight": 640,
        "decorations": false,
        "resizable": true,
        "center": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "resources": [
      "../tmp/*"
    ],
    "publisher": "A Book in 30 Minutes",
    "copyright": "Copyright 2026 A Book in 30 Minutes",
    "category": "Video",
    "shortDescription": "YouTube \u542c\u4e66\u89c6\u9891\u7d20\u6750\u751f\u6210\u5de5\u5177",
    "longDescription": "\u4ece EPUB \u751f\u6210 YouTube \u542c\u4e66\u89c6\u9891\u6240\u9700\u7684\u89c6\u9891\u6807\u9898\u3001\u7b80\u4ecb\u3001\u6807\u7b7e\u3001\u65c1\u767d\u7a3f\u548c\u5b57\u5e55\u7d20\u6750\u3002",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "perMachine",
        "languages": ["SimpChinese"],
        "displayLanguageSelector": false
      }
    }
  },
  "plugins": {}
}

