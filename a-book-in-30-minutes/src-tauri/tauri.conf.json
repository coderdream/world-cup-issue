{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "A Book in 30 Minutes",
  "version": "0.1.134",
  "identifier": "com.abookin30minutes.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:1421",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "A Book in 30 Minutes",
        "width": 1180,
        "height": 820,
        "minWidth": 920,
        "minHeight": 640,
        "decorations": false,
        "resizable": true,
        "center": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "resources": [
      "../tmp/*"
    ],
    "publisher": "A Book in 30 Minutes",
    "copyright": "Copyright 2026 A Book in 30 Minutes",
    "category": "Video",
    "shortDescription": "YouTube 听书视频素材生成工具",
    "longDescription": "从 EPUB 生成 YouTube 听书视频所需的视频标题、简介、标签、旁白稿和字幕素材。",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "perMachine",
        "languages": [
          "SimpChinese"
        ],
        "displayLanguageSelector": false
      }
    }
  },
  "plugins": {}
}
